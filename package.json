{
  "name": "tourneo",
  "version": "1.0.0",
  "description": "Tourneo - Premium Sports Event Platform for Padel Tournaments, Community & Discovery",
  "private": true,
  "workspaces": [
    "apps/mobile",
    "apps/backend"
  ],
  "scripts": {
    "test": "npm run backend:test && npm run mobile:test && npm run admin:check",
    "build": "npm run backend:build && npm run mobile:build",
    "ci:verify": "npm run mobile:typecheck && npm test && npm run build",
    "mobile": "npm run --workspace=apps/mobile",
    "backend": "npm run --workspace=apps/backend",
    "mobile:start": "npm run start --workspace=apps/mobile",
    "mobile:ios": "npm run ios --workspace=apps/mobile",
    "mobile:typecheck": "npm run typecheck --workspace=apps/mobile",
    "mobile:test": "npm test --workspace=apps/mobile",
    "mobile:build": "npm run build --workspace=apps/mobile",
    "backend:dev": "npm run dev --workspace=apps/backend",
    "backend:build": "npm run build --workspace=apps/backend",
    "backend:test": "npm test --workspace=apps/backend",
    "backend:migrate": "npm run migrate --workspace=apps/backend",
    "admin:check": "node scripts/check-admin-dashboard.mjs",
    "install:all": "npm install"
  },
  "author": "Lukas Gross <gross.lukas01@web.de>",
  "license": "UNLICENSED",
  "overrides": {
    "react": "19.1.0",
    "protobufjs": "^7.5.5",
    "@xmldom/xmldom": "^0.8.13",
    "fast-xml-parser": "^5.7.0",
    "follow-redirects": "^1.15.12",
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "react-native-worklets": "^0.8.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0"
  }
}
