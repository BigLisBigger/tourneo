# ============================================
# TURNEO BACKEND - ENVIRONMENT CONFIGURATION
# ============================================
# IMPORTANT: Never commit real credentials!
# Copy this file to .env and fill in your values.

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database (IONOS MariaDB)
DB_HOST=db5020220772.hosting-data.io
DB_PORT=3306
DB_NAME=dbs15550863
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_TABLE_PREFIX=turneo_

# JWT Authentication
JWT_ACCESS_SECRET=your_jwt_access_secret_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Stripe (Tournament Payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Apple In-App Purchase (Membership)
APPLE_SHARED_SECRET=your_apple_shared_secret
APPLE_BUNDLE_ID=com.turneo.app
APPLE_IAP_ENVIRONMENT=sandbox

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Email (SMTP)
SMTP_HOST=smtp.ionos.de
SMTP_PORT=587
SMTP_USER=your_email@turneo.de
SMTP_PASSWORD=your_email_password
SMTP_FROM_NAME=Turneo
SMTP_FROM_EMAIL=noreply@turneo.de

# Redis (optional – used for distributed rate limiting / brute-force protection)
REDIS_URL=

# File Storage (S3-compatible)
S3_ENDPOINT=your_s3_endpoint
S3_BUCKET=turneo-media
S3_ACCESS_KEY=your_s3_access_key
S3_SECRET_KEY=your_s3_secret_key
S3_REGION=eu-central-1

# App Configuration
APP_NAME=Turneo
APP_URL=https://app.turneo.de
ADMIN_URL=https://admin.turneo.de
SUPPORT_EMAIL=support@turneo.de

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Logging
LOG_LEVEL=debug