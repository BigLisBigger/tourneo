{
  "expo": {
    "name": "Turneo",
    "slug": "tourneo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A14"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.tourneo.app",
      "buildNumber": "2",
      "backgroundColor": "#0A0A14",
      "infoPlist": {
        "NSCameraUsageDescription": "Tourneo benötigt Zugriff auf die Kamera für dein Profilbild.",
        "NSPhotoLibraryUsageDescription": "Tourneo benötigt Zugriff auf deine Fotos für dein Profilbild.",
        "NSCalendarsUsageDescription": "Tourneo benötigt Zugriff auf deinen Kalender, um Turniertermine hinzuzufügen.",
        "NSFaceIDUsageDescription": "Tourneo nutzt Face ID für schnelles und sicheres Anmelden.",
        "NSLocationWhenInUseUsageDescription": "Tourneo nutzt deinen Standort, um Hallen in deiner Nähe anzuzeigen."
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A14"
      },
      "backgroundColor": "#0A0A14",
      "package": "de.tourneo.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": false,
      "enableDangerousExperimentalLeanBuilds": false
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      "expo-calendar",
      "expo-notifications",
      "expo-image-picker",
      "expo-apple-authentication",
      "expo-local-authentication",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Tourneo nutzt deinen Standort, um Hallen in deiner Nähe anzuzeigen."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "tourneo"
  }
}