{
  "expo": {
    "name": "Tourneo",
    "slug": "tourneo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#065B66"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "de.tourneo.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Tourneo benötigt Zugriff auf die Kamera für dein Profilbild.",
        "NSPhotoLibraryUsageDescription": "Tourneo benötigt Zugriff auf deine Fotos für dein Profilbild.",
        "NSCalendarsUsageDescription": "Tourneo benötigt Zugriff auf deinen Kalender, um Turniertermine hinzuzufügen."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#065B66"
      },
      "package": "de.tourneo.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "allowBackup": false,
      "enableDangerousExperimentalLeanBuilds": false
    },
    "plugins": ["expo-router", "expo-localization", "expo-secure-store", "expo-calendar"],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "tourneo"
  }
}