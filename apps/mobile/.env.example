# ============================================
# Tourneo Mobile App – Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
#
# For Expo, prefix all variables with EXPO_PUBLIC_ to make
# them accessible in the client bundle.
# ============================================

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1

# Stripe (public key only – secret key stays on backend)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Expo Push Notifications
EXPO_PUBLIC_EXPO_PROJECT_ID=your-expo-project-id

# Sentry Error Tracking (optional)
EXPO_PUBLIC_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Feature Flags
EXPO_PUBLIC_ENABLE_APPLE_SIGN_IN=true
EXPO_PUBLIC_ENABLE_BIOMETRICS=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true

# Environment
EXPO_PUBLIC_ENVIRONMENT=development